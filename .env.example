# 模板文件：复制为 .env 并填入实际值后提交到 git

# --- MySQL (Docker container: multi_agent_uav_system) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=uav_simulation

# --- Python 模块搜索路径 ---
# Windows 示例：
# PYTHONPATH=E:\Project\multi_agent_uav_system
# Linux / macOS 示例：
# PYTHONPATH=/home/user/multi_agent_uav_system
PYTHONPATH=
